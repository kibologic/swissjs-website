import { mount, Signal, SwissComponent } from '@kibologic/core';
import { LandingPage } from './pages/LandingPage.uix';
import { DocsPage } from './pages/DocsPage.uix';

const route$ = new Signal(window.location.pathname);

const normalize = (p: string) => {
  if (!p) return '/';
  if (p.length > 1 && p.endsWith('/')) return p.slice(0, -1);
  return p;
};

window.addEventListener('popstate', () => {
  route$.value = normalize(window.location.pathname);
  window.scrollTo(0, 0);
});

// Global internal link interceptor
document.addEventListener('click', (e: any) => {
  const link = e.target.closest('a');
  if (link && link.href && link.href.startsWith(window.location.origin) && !link.target && !e.metaKey && !e.ctrlKey) {
    const path = link.getAttribute('href');
    if (path && path.startsWith('/') && !path.includes('#')) {
      e.preventDefault();
      history.pushState(null, '', path);
      route$.value = normalize(path);
      window.scrollTo(0, 0);
    }
  }
});

component Router {
  render() {
    const r = normalize(route$.value);
    if (r === '/' || r === '') return <LandingPage />;
    if (r.startsWith('/docs')) return <DocsPage route={r} />;
    return <LandingPage />;
  }
}

mount(Router, document.getElementById('app'));
