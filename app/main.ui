import { mount, Signal } from '@kibologic/core';
import { LandingPage } from './pages/LandingPage.uix';
import { DocsPage } from './pages/DocsPage.uix';

const route$ = new Signal(window.location.hash || '#/');

window.addEventListener('hashchange', () => {
  route$.value = window.location.hash || '#/';
  window.scrollTo(0, 0);
});

component Router {
  render() {
    const r = route$.value;
    if (r === '#/' || r === '') return <LandingPage />;
    if (r.startsWith('#/docs')) return <DocsPage route={r} />;
    return <LandingPage />;
  }
}

mount(Router, document.getElementById('app'));
