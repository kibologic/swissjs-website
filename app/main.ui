import { mount, Signal, SwissComponent, createElement, Fragment } from ‘@kibologic/core’;
import { LandingPage } from ‘./pages/LandingPage.uix’;
import { DocsRouter } from ‘./pages/docs/DocsRouter.uix’;

globalThis.createElement = createElement;
globalThis.Fragment = Fragment;

const route$ = new Signal(window.location.pathname);

window.addEventListener(‘popstate’, () => {
  route$.value = window.location.pathname;
  window.scrollTo(0, 0);
});

document.addEventListener(‘click’, (e: any) => {
  const link = e.target.closest(‘a’);
  if (link && link.href && link.href.startsWith(window.location.origin) && !link.target && !e.metaKey && !e.ctrlKey) {
    const path = link.getAttribute(‘href’);
    if (path && path.startsWith(‘/’) && !path.includes(‘#’)) {
      e.preventDefault();
      history.pushState(null, ‘’, path);
      route$.value = path;
      window.scrollTo(0, 0);
    }
  }
});

component Router {
  render() {
    const r = route$.value;
    if (r === ‘/’ || r === ‘’) return <LandingPage />;
    if (r.startsWith(‘/docs’)) return <DocsRouter route={r} />;
    return <LandingPage />;
  }
}

mount(Router, document.getElementById('app'));
